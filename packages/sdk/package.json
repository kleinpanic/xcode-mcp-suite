{
  "name": "@kleinpanic/xcode-mcp-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Xcode's MCP bridge (xcrun mcpbridge)",
  "license": "MIT",
  "author": "kleinpanic",
  "repository": { "type": "git", "url": "https://github.com/kleinpanic/xcode-mcp-suite" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "@types/node": "*"
  }
}
